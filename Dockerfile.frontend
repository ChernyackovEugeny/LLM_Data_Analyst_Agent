# --- Этап 1: сборка React-приложения ---
# Node строит production bundle в папку dist/
FROM node:20-alpine AS build
WORKDIR /app

# Копируем package.json отдельно — слой с node_modules кешируется
# и не пересобирается при изменении только исходного кода
COPY client/package*.json ./
RUN npm install

# Копируем исходный код и собираем
COPY client/ .
RUN npm run build

# --- Этап 2: раздача статики через nginx ---
# Финальный образ содержит только nginx + собранный dist/, без Node.js
FROM nginx:alpine

# Копируем собранную статику из первого этапа
COPY --from=build /app/dist /usr/share/nginx/html

# Копируем наш конфиг nginx (proxy на бэкенд, SPA routing)
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
