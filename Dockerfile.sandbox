# =============================================================
# Sandbox image для изолированного выполнения Python-кода агента.
#
# Намеренно МИНИМАЛЬНЫЙ образ — содержит только библиотеки для
# анализа данных. НЕ содержит:
#   - FastAPI, uvicorn или любой веб-фреймворк
#   - SQLAlchemy или драйверы БД
#   - Исходный код приложения (app/)
#   - Учётные данные или переменные окружения
#
# Почему python:3.11-slim, а не Alpine:
#   Alpine использует musl libc — известны проблемы совместимости
#   с numpy/scipy C-расширениями, скомпилированными под glibc.
#   slim = тот же glibc что в Dockerfile.backend = идентичное поведение.
#
# Версии пакетов совпадают с requirements.txt:
#   Несоответствие версий привело бы к расхождению поведения между
#   тестом в dev и выполнением в sandbox. Идентичные версии = идентичный результат.
# =============================================================

FROM python:3.11-slim

# Устанавливаем только библиотеки для анализа данных.
# requests, urllib3, httpx — намеренно НЕ устанавливаются,
# чтобы даже при гипотетическом обходе network_disabled не было
# удобных HTTP-клиентов для exfiltration данных.
RUN pip install --no-cache-dir \
    pandas==2.2.1 \
    matplotlib==3.8.3 \
    scipy==1.17.1

WORKDIR /workspace

# Создаём директорию для графиков заранее.
# Без этого Docker при монтировании volume создаст её от root:root,
# что заблокирует запись для непривилегированного пользователя.
RUN mkdir -p /workspace/static/plots

# Запускаем от непривилегированного пользователя.
# При гипотетическом container escape non-root ограничивает
# доступ к хосту — root-процесс мог бы писать в произвольные
# хостовые пути, non-root — нет.
RUN useradd --uid 1000 --no-create-home --shell /bin/false sandboxuser
RUN chown -R sandboxuser:sandboxuser /workspace
USER sandboxuser
